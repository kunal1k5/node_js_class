<!DOCTYPE html>
<html>
    <head>
        <title><%= title %></title>
        <style>
            .nav1{
                font-size: 20px;
                font-family: 'Times New Roman', Times, serif;
                margin: 0px;
            }
            .container {
                display: flex;
                gap: 20px;
                padding: 20px;
            }
            .box{
                width: 250px;
                background: white;
                border: 2px solid black;
                padding: 10px;
            }
            textarea{
                width: 100%;
                height: 200px;
                border: none;
                outline: none;
                font-size: 14px;
            }
            iframe{
                width: 50%;
                height: 400px;
                border: none;
            }
            h4 {
                margin-top: 0;
            }
        </style>
    </head>
    <body>
        <%- include("header") %>
        <h6 style="margin-left: 20px;">Html Editor</h6>
        <div class="container">
            <div class="box">
                <h4>My Code</h4>

                <textarea id = "code" placeholder="Write your code here...."></textarea>
            </div>

            <div class="box">

                <h4>Preview Code</h4>
                <iframe id="preview"></iframe>

            </div>
        </div>
        <script>
            const code = document.getElementById("code");
            const preview = document.getElementById("preview");
            code.addEventListener("keyup", ()=>{
                preview.srcdoc = code.value;
            })
        </script>
    </body>
</html>