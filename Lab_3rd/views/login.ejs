<!DOCTYPE html>
<html>
<head>
  <title>Login</title>
</head>
<body>
  <h1>Login Page</h1>
  <% if (message) { %>
    <p><%= message %></p>
  <% } %>
  <form action="/login" method="post">
    <label>Username:</label>
    <input type="text" name="username" />
    <br />
    <label>Password:</label>
    <input type="password" name="password" />
    <br />
    <button type="submit">Login</button>
  </form>
</body>
</html>
